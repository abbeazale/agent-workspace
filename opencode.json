{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "allow",
    "bash": {
      "*": "allow",
      "rm *": "deny",
      "rm -rf *": "deny",
      "rmdir *": "deny",
      "git push *": "deny",
      "git commit *": "deny",
      "git reset --hard *": "deny",
      "git clean *": "deny"
    }
  }
}
